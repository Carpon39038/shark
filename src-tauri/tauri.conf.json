{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shark",
  "version": "0.1.0",
  "identifier": "com.shark.asset-manager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Shark",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGMTE2MTQ0MEE0RDg1NQpSV1JWMktSQUZCYnhDdnVDY0w2TjlOeTNsZ3ZxV2llNWpIKzVaUTBVU3BteGJhb1JYQzd6dGhKdgo=",
      "endpoints": [
        "https://github.com/Carpon39038/shark/releases/latest/download/latest.json"
      ]
    }
  }
}
